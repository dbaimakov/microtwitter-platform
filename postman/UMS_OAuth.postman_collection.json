{
  "info": {
    "name": "UMS Assignment 4 OAuth2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login Local",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Start GitHub OAuth Login",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login/github",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login",
            "github"
          ]
        }
      }
    },
    {
      "name": "Current User by UUID Token",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Auth-Token",
            "value": "{{uuidToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "Validate UUID Token Internally",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/internal/auth/validate?token={{uuidToken}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "internal",
            "auth",
            "validate"
          ],
          "query": [
            {
              "key": "token",
              "value": "{{uuidToken}}"
            }
          ]
        }
      }
    },
    {
      "name": "Inspect JWT",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/jwt/inspect?token={{jwtToken}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "jwt",
            "inspect"
          ],
          "query": [
            {
              "key": "token",
              "value": "{{jwtToken}}"
            }
          ]
        }
      }
    },
    {
      "name": "Logout UUID Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-Auth-Token",
            "value": "{{uuidToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "logout"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "uuidToken",
      "value": ""
    },
    {
      "key": "jwtToken",
      "value": ""
    }
  ]
}
